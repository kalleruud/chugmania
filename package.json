{
  "name": "chugmania",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "backend/src/server.ts",
  "scripts": {
    "start": "node dist/server/server.js",
    "dev": "tsx watch --env-file .env backend/src/server.ts",
    "check": "node scripts/check.js",
    "fix": "eslint . --cache --fix && prettier -w .",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "vite build",
    "build:backend": "tsup backend/src/server.ts --format esm --target node20 --out-dir dist/server --clean",
    "db:gen": "drizzle-kit generate",
    "db:push": "drizzle-kit push --force",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-toggle": "^1.1.12",
    "@radix-ui/react-toggle-group": "^1.1.13",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "glicko2": "^1.2.1",
    "ics": "^3.12.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.21.0",
    "luxon": "^3.7.2",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-router": "^8.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2",
    "vite-express": "^0.22.1"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@fontsource/titillium-web": "^5.2.8",
    "@rolldown/plugin-babel": "^0.2.3",
    "@eslint/js": "^9.39.2",
    "@tailwindcss/vite": "^4.3.1",
    "@types/babel__core": "^7.20.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/luxon": "^3.7.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^17.7.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.1",
    "tailwindcss-safe-area": "^1.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^8.1.0"
  },
  "allowScripts": {
    "esbuild": true,
    "better-sqlite3": true,
    "fsevents": true
  }
}
